{
  "manifest_version": 3,
  "name": "VisaFlowX",
  "description": "Production-grade IVAC signin workflow assistant with autofill, verification wait, retry scheduling, OTP alerts, and alarm controls.",
  "version": "2.0.0",
  "minimum_chrome_version": "116",
  "permissions": [
    "storage",
    "notifications",
    "tabs",
    "scripting",
    "activeTab",
    "alarms"
  ],
  "host_permissions": [
    "https://appointment.ivacbd.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_title": "VisaFlowX",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://appointment.ivacbd.com/*"
      ],
      "js": [
        "utils/storage.js",
        "utils/timers.js",
        "utils/parser.js",
        "utils/dom-utils.js",
        "content/notification-handler.js",
        "content/detector.js",
        "content/retry-engine.js",
        "content/otp-monitor.js",
        "content/automation.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "commands": {
    "toggle-automation": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Start or stop VisaFlowX automation"
    }
  }
}
