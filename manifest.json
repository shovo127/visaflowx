{
  "manifest_version": 3,
  "name": "VisaFlowX Universal",
  "description": "Universal browser workflow assistant with profile-driven monitoring, scheduling, retry handling, and safe protected-challenge waiting.",
  "version": "1.0.1",
  "minimum_chrome_version": "116",
  "action": {
    "default_title": "VisaFlowX Universal",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "alarms",
    "notifications",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "utils/constants.js",
        "utils/logger.js",
        "utils/timers.js",
        "utils/dom-utils.js",
        "utils/parser.js",
        "rules/rule-engine.js",
        "rules/action-runner.js",
        "content/otp-detector.js",
        "content/notification-handler.js",
        "content/overlay-selector.js",
        "content/monitor.js",
        "content/bootstrap.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "commands": {
    "toggle-monitoring": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Start or stop the active VisaFlowX Universal workflow"
    }
  }
}
